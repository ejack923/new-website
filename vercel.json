{
  "redirects": [
    {
      "source": "/home",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/services",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/workflow-tools",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/workflow-tools-access",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/lacw-emails/:path*",
      "destination": "https://deadline-website.onrender.com/api/lacw-emails/:path*"
    },
    {
      "source": "/api/app/uploads/:path*",
      "destination": "https://deadline-website.onrender.com/api/app/uploads/:path*"
    },
    {
      "source": "/lacw-portal-tool",
      "destination": "/lacw-portal-tool/index.html"
    },
    {
      "source": "/api/admin/operators",
      "destination": "/api/admin/operators.js"
    },
    {
      "source": "/api/submissions/:id/comments",
      "destination": "/api/submissions.js"
    },
    {
      "source": "/api/submissions/:id",
      "destination": "/api/submissions.js"
    },
    {
      "source": "/api/submissions",
      "destination": "/api/submissions.js"
    },
    {
      "source": "/((?!api/|lacw-portal-tool).*)",
      "destination": "/index.html"
    }
  ]
}